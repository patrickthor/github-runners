# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files
*.tfplan
*.tfplan.*
tfplan

# Ignore lock file (optional - some teams commit this)
# .terraform.lock.hcl

# Ignore any .terraform.lock.hcl backup files
.terraform.lock.hcl.backup

# Ignore test files
*.test
*.test.*

# Ignore backup files
*.backup
*.bak
*~

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.idea/
*.iml
*.iws
.vscode/
*.swp
*.swo
*~
.project
.settings/
.classpath

# Ignore sensitive files
*.pem
*.key
*.crt
*.p12
*.pfx
secrets.auto.tfvars
